{
  "compilerOptions": {
    "target": "es2017",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "pretty": true,
    "sourceMap": false,
    "outDir": "./dist",
    "allowJs": true,
    "noEmit": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "removeComments": true,
    "declaration": false,
    "typeRoots": ["./node_modules/@types"],
    "jsx": "react"
  },
  "include": [
    "./src/**/*",
    "./drizzle.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    // "**/*.spec.ts",
    // "**/*.test.ts"
  ]
}